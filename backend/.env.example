# AniList OAuth Configuration
ANILIST_CLIENT_ID=your_client_id_here
ANILIST_CLIENT_SECRET=your_client_secret_here
ANILIST_REDIRECT_URI=http://localhost:3001/api/auth/callback

# Server Configuration
PORT=3001
NODE_ENV=development

# CORS - Extension ID (replace with your actual extension ID)
EXTENSION_ORIGIN=chrome-extension://your-extension-id
